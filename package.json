{
  "name": "ocr-extractor",
  "version": "2.2.0",
  "description": "Obsidian plugin to extract text from PDFs, documents, images, etc. with OCR and store it as Markdown in notes",
  "main": "main.js",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "test": "vitest",
    "test:e2e": "playwright test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint",
    "version": "node version-bump.mjs"
  },
  "keywords": [],
  "author": "Johnathan Ritzi",
  "license": "MIT",
  "devDependencies": {
    "@electron/asar": "^4.1.2",
    "@eslint/compat": "^2.0.5",
    "@eslint/js": "^9.39.2",
    "@mswjs/interceptors": "^0.41.6",
    "@playwright/test": "^1.58.2",
    "@tesseract.js-data/eng": "^1.0.0",
    "@types/node": "^24.10.13",
    "electron": "39.8.3",
    "esbuild": "0.28.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-obsidianmd": "^0.2.9",
    "generate-license-file": "^4.1.1",
    "globals": "^17.5.0",
    "jiti": "^2.5.1",
    "obsidian": "^1.12.3",
    "prettier": "3.8.3",
    "tslib": "2.8.1",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@mistralai/mistralai": "^2.2.1",
    "file-type": "^22.0.1",
    "i18next": "^26.0.6",
    "pdfjs-dist": "5.4.624",
    "tesseract.js": "^7.0.0"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.1.1+sha512.d1fdf5f73c617b64fa1a56a81c3c8dfe0e966e33a6010aa256b517ae77be21d93e05affc0de1a83b0e4f29d569f68b446ae8f068cd7247c0bb3df0fb4d7bdf9a"
}
