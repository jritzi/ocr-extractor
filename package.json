{
  "name": "ocr-extractor",
  "version": "2.2.2",
  "description": "Obsidian plugin to extract text from PDFs, documents, images, etc. with OCR and store it as Markdown in notes",
  "main": "main.js",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "test": "vitest",
    "test:e2e": "playwright test --project=latest",
    "test:e2e:all": "playwright test",
    "latest-obsidian": "node scripts/latest-obsidian.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint",
    "version": "node scripts/version-bump.mjs"
  },
  "keywords": [],
  "author": "Johnathan Ritzi",
  "license": "MIT",
  "devDependencies": {
    "@electron/asar": "^4.1.2",
    "@eslint/config-helpers": "^0.6.0",
    "@eslint/js": "^9.39.2",
    "@mswjs/interceptors": "^0.41.6",
    "@playwright/test": "^1.60.0",
    "@tesseract.js-data/eng": "^1.0.0",
    "@types/node": "^24.10.13",
    "@types/semver": "^7.7.1",
    "esbuild": "0.28.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-obsidianmd": "^0.2.9",
    "generate-license-file": "^4.2.1",
    "globals": "^17.6.0",
    "vite": "^8.0.16",
    "jiti": "^2.5.1",
    "obsidian": "^1.12.3",
    "prettier": "3.8.3",
    "tslib": "2.8.1",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@mistralai/mistralai": "^2.2.5",
    "file-type": "^22.0.1",
    "i18next": "^26.0.6",
    "openai": "^6.42.0",
    "pdfjs-dist": "5.4.624",
    "semver": "^7.8.0",
    "tesseract.js": "^7.0.0"
  },
  "engines": {
    "node": ">=24"
  },
  "pnpm": {
    "overrides": {
      "ws": "^8.20.1",
      "minimatch@8": "^8.0.6",
      "minimatch@9": "^9.0.7",
      "fast-uri": "^3.1.2"
    }
  },
  "packageManager": "pnpm@10.33.4+sha512.1c67b3b359b2d408119ba1ed289f34b8fc3c6873412bec6fd264fbdc82489e510fcbecb9ce9d22dae7f3b76269d8441046014bdca53b9979cd7a561ad631b800"
}
