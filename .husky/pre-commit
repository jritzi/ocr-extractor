if git diff --cached --name-only | grep -q '^pnpm-lock\.yaml$'; then
  echo "Regenerating THIRD_PARTY_LICENSES.txt"
  pnpm generate-licenses
  git add THIRD_PARTY_LICENSES.txt
fi

api_src_changed=$(git diff --cached --name-only | grep '^ocr-extractor-api/src/' | grep -v '\.test\.ts$' || true)
if [ -n "$api_src_changed" ]; then
  echo "Regenerating API docs"
  pnpm --filter ocr-extractor-api docs
  git add ocr-extractor-api/docs
fi
